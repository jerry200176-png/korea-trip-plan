---
import { siteBase } from "../lib/base";
import "../styles/global.css";

interface Props {
  title: string;
  current?: string;
  hideDock?: boolean;
}

const { title, current = "", hideDock = false } = Astro.props;
const base = siteBase();

const links = [
  { href: base, id: "home", label: "首頁" },
  { href: `${base}today/day-2/`, id: "today", label: "今日" },
  { href: `${base}days/`, id: "days", label: "行程" },
  { href: `${base}decisions/`, id: "decisions", label: "決策" },
  { href: `${base}emergency/`, id: "emergency", label: "緊急" },
];
---
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#f7f4ed" />
    <meta name="description" content="Jerry 與女友 — 第一次韓國旅行書" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;600&family=Noto+Sans+TC:wght@400;600&family=Noto+Serif+TC:wght@600&display=swap"
      rel="stylesheet"
    />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <title>{title} · 我們的韓國</title>
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <div>
          <div class="brand">我們的韓國</div>
          <div class="brand-tagline">Jerry 與女友 · 第一次一起出國</div>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        旅行書 · 資料來自 data/*.yaml · 不含訂位碼
      </footer>
    </div>
    {
      !hideDock && (
        <nav class="nav-dock" aria-label="主選單">
          <div class="nav-dock-inner">
            {links.map((l) => (
              <a href={l.href} aria-current={current === l.id ? "page" : undefined}>
                {l.label}
              </a>
            ))}
          </div>
        </nav>
      )
    }
    <script define:vars={{ swUrl: `${base}sw.js` }}>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register(swUrl).catch(() => {});
        });
      }
    </script>
  </body>
</html>
