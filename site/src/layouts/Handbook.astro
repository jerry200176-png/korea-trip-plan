---
import Base from "./Base.astro";
import "../styles/global.css";

interface Props {
  title: string;
  current?: string;
}

const { title, current = "" } = Astro.props;
const base = import.meta.env.BASE_URL;

const links = [
  { href: base, id: "home", label: "首頁" },
  { href: `${base}today/`, id: "today", label: "今日" },
  { href: `${base}days/`, id: "days", label: "行程" },
  { href: `${base}food/`, id: "food", label: "餐飲" },
  { href: `${base}emergency/`, id: "emergency", label: "緊急" },
  { href: `${base}more/`, id: "more", label: "更多" },
];
---
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0f1419" />
    <meta name="description" content="Jerry 與女友韓國旅行手冊 — 手機優先、可離線" />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <title>{title} · Korea Trip</title>
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <div>
          <div class="brand">Korea Trip</div>
          <div class="muted" style="font-size:0.85rem">Jerry & 女友 · 作戰手冊</div>
        </div>
        <span class="badge provisional">Provisional</span>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        單一資料來源：data/*.yaml · 勿寫入私密訂位碼
      </footer>
    </div>
    <nav class="nav-dock" aria-label="主選單">
      <div class="nav-dock-inner">
        {
          links.map((l) => (
            <a href={l.href} aria-current={current === l.id ? "page" : undefined}>
              {l.label}
            </a>
          ))
        }
      </div>
    </nav>
    <script>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          const sw = `${import.meta.env.BASE_URL}sw.js`;
          navigator.serviceWorker.register(sw).catch(() => {});
        });
      }
    </script>
  </body>
</html>
