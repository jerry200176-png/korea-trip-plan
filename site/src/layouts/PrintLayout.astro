---
interface Props {
  title: string;
  publication?: "handbook" | "emergency" | "proof";
}

import "../styles/print.css";

const { title, publication = "handbook" } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="publication-mode" content={publication} />
  </head>
  <body class={`print-root print-${publication}`}>
    <div id="publication-root" class="publication-flow">
      <slot />
    </div>
    <script is:inline src={`${base}vendor/paged.polyfill.js`}></script>
    <script is:inline>
      window.__PUBLICATION_READY__ = new Promise((resolve) => {
        const done = () => resolve(true);
        if (document.querySelector(".pagedjs_pages")) return done();
        document.addEventListener("pagedjs:rendered", done, { once: true });
        setTimeout(done, 45000);
      });
    </script>
  </body>
</html>
