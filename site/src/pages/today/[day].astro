---
import { siteBase } from "../../lib/base";
import Handbook from "../../layouts/Handbook.astro";
import { loadItinerary, loadPlaces, mediaById, mediaPublicUrl } from "../../lib/data";
import {
  cityZh,
  formatClock,
  sanitizeReaderText,
  statusZh,
  transitModeZh,
} from "../../lib/presentation";

export function getStaticPaths() {
  const days = loadItinerary().days;
  return days.map((d) => ({ params: { day: `day-${d.day_index}` } }));
}

const dayParam = Astro.params.day!;
const dayIndex = Number(dayParam.replace("day-", ""));
const day = loadItinerary().days.find((d) => d.day_index === dayIndex)!;
const places = Object.fromEntries(loadPlaces().map((p) => [p.id, p]));
const base = siteBase();
const mood = dayIndex === 2 ? mediaById("seoul-palace-gate") : null;

const nextBlock =
  day.blocks.find((b: { droppable?: boolean; kind: string }) => !b.droppable && b.kind !== "buffer" && b.kind !== "rest") ??
  day.blocks[0];

let mapPlace: { naver_map_url?: string; name_zh: string; name_ko?: string; address?: string; area?: string } | null = null;
for (const b of day.blocks) {
  if (b.place_id && places[b.place_id]) {
    mapPlace = places[b.place_id];
    break;
  }
}

const transit = nextBlock ? transitModeZh(nextBlock.transit_mode) : null;
---
<Handbook title={`今日 · Day ${day.day_index}`} current="today">
  <p class="muted">
    <a href={`${base}today/`}>← 換一天</a>
  </p>
  <p class="eyebrow">今日執行 · Day {day.day_index} · {cityZh(day.city)}</p>
  <h1 class="page-title" style="font-size:1.25rem">{sanitizeReaderText(day.theme)}</h1>
  <span class="status status-provisional">{statusZh(day.status)}</span>

  <section class="surface-warm">
    <h2 style="margin-top:0">今天只做這件事</h2>
    <p style="font-size:1.15rem;line-height:1.45;margin:0">{sanitizeReaderText(day.one_priority)}</p>
    <p class="muted" style="margin-top:var(--space-3)">
      最晚回住宿 <strong>{day.return_by}</strong> · 出門目標 {day.out_time}
    </p>
  </section>

  {
    mood && (
      <img
        class="today-visual"
        src={mediaPublicUrl(base, mood)}
        alt={mood.alt_zh}
        loading="lazy"
      />
    )
  }

  {
    nextBlock && (
      <section class="surface">
        <h2 style="margin-top:0">下一動</h2>
        <p style="margin:0">
          <strong>{sanitizeReaderText(nextBlock.title)}</strong>
        </p>
        <p class="muted">
          {formatClock(nextBlock.start)} – {formatClock(nextBlock.end)}
          {transit ? ` · ${transit}` : ""}
          {nextBlock.transit_minutes != null ? ` · 約 ${nextBlock.transit_minutes} 分` : ""}
        </p>
        {nextBlock.plan_b && (
          <p class="muted">
            <strong>備案：</strong>
            {sanitizeReaderText(nextBlock.plan_b)}
          </p>
        )}
      </section>
    )
  }

  <section class="surface">
    <h2 style="margin-top:0">一鍵</h2>
    <div class="btn-row">
      {
        mapPlace?.naver_map_url && (
          <a class="btn primary" href={mapPlace.naver_map_url} target="_blank" rel="noreferrer">
            開啟 Naver Map
          </a>
        )
      }
      <a class="btn" href={`${base}days/${dayParam}/`}>
        完整行程
      </a>
      <a class="btn" href={`${base}emergency/`}>
        緊急
      </a>
    </div>
    {
      mapPlace && (
        <p class="muted" style="margin-top:var(--space-3)">
          <strong>{mapPlace.name_zh}</strong>
          {mapPlace.name_ko ? <> · <span lang="ko">{mapPlace.name_ko}</span></> : null}
          · 地址出發前再確認
        </p>
      )
    }
  </section>

  <section class="surface-quiet">
    <h2 style="margin-top:0">若下雨／體力低</h2>
    <p class="muted" style="margin:0"><strong>雨備：</strong>{sanitizeReaderText(day.rain_plan)}</p>
    <p class="muted"><strong>低體力優先刪除：</strong>{(day.droppable_items || []).map((x: string) => sanitizeReaderText(String(x))).join("、") || sanitizeReaderText(day.low_energy_plan)}</p>
    <p class="muted">
      <strong>回住宿方向：</strong>
      {sanitizeReaderText(day.emergency_return)}
    </p>
  </section>
</Handbook>
