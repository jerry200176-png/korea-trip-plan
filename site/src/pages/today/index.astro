---
import { siteBase } from "../../lib/base";
import Handbook from "../../layouts/Handbook.astro";
import { loadItinerary } from "../../lib/data";
import { cityZh, sanitizeReaderText } from "../../lib/presentation";

const days = loadItinerary().days.slice().sort((a, b) => a.day_index - b.day_index);
const base = siteBase();
---
<Handbook title="今日" current="today">
  <header class="page-intro">
    <p class="eyebrow">執行模式</p>
    <h1 class="page-title">今日模式</h1>
    <p class="hero-lede">出國當天：一件事、下一動、地圖、緊急 — 十秒內看懂。</p>
    <span class="status status-provisional">預覽模式</span>
  </header>

  <section class="reveal">
    <h2 style="margin-top:0">選一天</h2>
    <ul class="day-picker">
      {
        days.map((d) => (
          <li>
            <a class="day-picker-link" href={`${base}today/day-${d.day_index}/`}>
              <span class="day-picker-index">Day {d.day_index}</span>
              <span>
                <p class="day-picker-theme">{sanitizeReaderText(d.theme)}</p>
                <p class="day-picker-hint muted">{cityZh(d.city)} · {sanitizeReaderText(d.one_priority)}</p>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <p class="muted" style="margin-top:var(--space-5)">
    <a class="back-link" href={`${base}`}>← 首頁</a>
  </p>
</Handbook>
