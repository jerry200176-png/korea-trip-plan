---
import Handbook from "../../layouts/Handbook.astro";
---

<Handbook title="Design Lab" hideDock={true}>
  <p class="eyebrow">Maintainer only</p>
  <h1 class="page-title">Design Lab</h1>
  <p class="hero-lede">內部元件對照 — 依根目錄 DESIGN.md（Warm Editorial Journey）。不在 Couple Preview 導覽中。</p>

  <section class="surface">
    <h2 style="margin-top:0">Palette</h2>
    <div class="design-lab-grid">
      <div><div class="design-lab-swatch" style="background:var(--color-canvas)"></div><span class="muted">canvas</span></div>
      <div><div class="design-lab-swatch" style="background:var(--color-ink)"></div><span class="muted">ink</span></div>
      <div><div class="design-lab-swatch" style="background:var(--color-primary)"></div><span class="muted">primary</span></div>
      <div><div class="design-lab-swatch" style="background:var(--color-accent-warm)"></div><span class="muted">accent</span></div>
      <div><div class="design-lab-swatch" style="background:var(--color-seoul)"></div><span class="muted">seoul</span></div>
      <div><div class="design-lab-swatch" style="background:var(--color-busan)"></div><span class="muted">busan</span></div>
    </div>
  </section>

  <section class="surface">
    <h2 style="margin-top:0">Typography</h2>
    <p style="font-family:var(--font-serif);font-size:1.75rem;margin:0">第一次一起出國 · 韓國</p>
    <p style="font-family:var(--font-sans);margin:var(--space-3) 0 0">內文 Noto Sans TC · <span lang="ko">부산 해운대</span></p>
  </section>

  <section class="surface">
    <h2 style="margin-top:0">Buttons & status</h2>
    <div class="btn-row">
      <span class="btn primary">主要</span>
      <span class="btn">次要</span>
    </div>
    <div class="chip-row" style="margin-top:var(--space-4)">
      <span class="status status-confirmed">已確認</span>
      <span class="status status-provisional">暫定</span>
      <span class="status status-decision">待決策</span>
    </div>
  </section>

  <section class="surface-quiet">
    <h2 style="margin-top:0">Day timeline</h2>
    <div class="route-line">
      <article class="route-node">
        <div class="time">09:00 – 10:00</div>
        <strong>宮殿入場</strong>
      </article>
      <article class="route-node transit">
        <div class="time">10:00 – 10:30</div>
        <strong>地鐵</strong>
      </article>
    </div>
  </section>

  <section class="surface city-ribbon seoul">
    <p class="eyebrow">Seoul band</p>
    <p>首爾四晚 — 區域識別色帶</p>
  </section>

  <section class="surface city-ribbon busan">
    <p class="eyebrow">Busan band</p>
    <p>釜山兩晚 — 區域識別色帶</p>
  </section>

  <section class="surface-warm">
    <h2 style="margin-top:0">Decision card</h2>
    <p>兩人還在談的選項，附暫定標籤。</p>
    <span class="status status-decision">待決策</span>
  </section>

  <section class="surface-emergency">
    <h2 style="margin-top:0">Emergency card</h2>
    <p style="font-size:1.25rem;font-family:var(--font-serif)">112 · 119</p>
  </section>

  <section class="surface">
    <h2 style="margin-top:0">Bottom navigation (preview)</h2>
    <div class="nav-dock" style="position:relative;box-shadow:none;margin-top:var(--space-3)">
      <div class="nav-dock-inner">
        <span class="btn-ghost" style="min-height:var(--tap)">首頁</span>
        <span class="btn-ghost" style="min-height:var(--tap)">今日</span>
        <span class="btn-ghost" style="min-height:var(--tap)">行程</span>
        <span class="btn-ghost" style="min-height:var(--tap)">決策</span>
        <span class="btn-ghost" style="min-height:var(--tap)">緊急</span>
      </div>
    </div>
  </section>

  <section class="surface" style="break-inside:avoid">
    <h2 style="margin-top:0">Print sample</h2>
    <p class="muted">PDF 封面語彙：米白底、襯線大標、細線目錄。</p>
    <div style="border:1px solid var(--color-border);padding:var(--space-5);background:var(--color-canvas)">
      <p class="eyebrow">Chapter</p>
      <p style="font-family:var(--font-serif);font-size:1.5rem;margin:0">Day 2 · 韓服與宮殿</p>
    </div>
  </section>
</Handbook>
