---
import { siteBase } from "../lib/base";
import Handbook from "../layouts/Handbook.astro";
import { loadRestaurants, mediaById, mediaPublicUrl } from "../lib/data";
import { areaZh, cityZh, sanitizeReaderText, statusZh } from "../lib/presentation";
import { relatedDaysForGuide } from "../lib/guide-links";

const restaurants = loadRestaurants();
const base = siteBase();
const foodMedia = mediaById("seoul-street-food")!;
const identify = mediaById("food-identify-cards")!;
const order = mediaById("food-order-korean-cards")!;
const warn = mediaById("food-crustacean-shrimp-warn")!;
const bbq = mediaById("food-bbq-cuts-compare")!;
const market = mediaById("food-market-snack-identify")!;
const queue = mediaById("food-queue-or-alt-decision")!;
const porkCard = mediaById("busan-pork-order")!;
const relatedDays = relatedDaysForGuide("food");

function riskZh(v: string) {
  const map: Record<string, string> = {
    low: "低",
    medium: "中",
    high: "高",
    unknown: "出發前再確認",
  };
  return map[v] ?? "出發前再確認";
}
---
<Handbook title="美食" current="guides">
  <p class="eyebrow">美食教材</p>
  <h1 class="page-title">辨識・點餐・避雷</h1>
  <span class="status status-provisional">目前暫定</span>
  <p class="muted">給 Jerry 與 Nikita 的食物教材。不保證零甲殼類；不為熱門店排過久；腳累不跨區吃一餐。</p>

  <figure class="media-block">
    <img src={mediaPublicUrl(base, foodMedia)} alt={foodMedia.alt_zh} loading="lazy" />
    <figcaption class="media-caption">{foodMedia.alt_zh}</figcaption>
  </figure>

  <section class="surface">
    <h2 style="margin-top:0">硬性規則</h2>
    <ul class="list">
      <li>不喝酒</li>
      <li>不安排甲殼類海鮮為主的餐廳；現場仍要問蝦醬</li>
      <li>可吃辣</li>
      <li>不想啃骨頭、不吃內臟時要說清楚</li>
      <li>排隊約超過 1 小時就改備案</li>
      <li>腳累時不要為一餐跨區</li>
    </ul>
  </section>

  <section class="surface-warm">
    <h2 style="margin-top:0">食物怎麼辨識</h2>
    <figure class="media-block">
      <img src={mediaPublicUrl(base, identify)} alt={identify.alt_zh} loading="lazy" />
      <figcaption class="media-caption">{identify.alt_zh}</figcaption>
    </figure>
    <ul class="list">
      <li>豬肉湯飯、韓國烤肉、早餐、市場小吃、咖啡甜點、便利商店、車站／移動日快速餐</li>
      <li>雨天備援：室內韓式／便利商店／住宿附近，不追戶外排隊</li>
    </ul>
  </section>

  <section class="surface">
    <h2 style="margin-top:0">點餐韓文卡</h2>
    <figure class="media-block">
      <img src={mediaPublicUrl(base, order)} alt={order.alt_zh} loading="lazy" />
      <figcaption class="media-caption">{order.alt_zh}</figcaption>
    </figure>
  </section>

  <section class="surface">
    <h2 style="margin-top:0">甲殼類／蝦醬提醒</h2>
    <figure class="media-block">
      <img src={mediaPublicUrl(base, warn)} alt={warn.alt_zh} loading="lazy" />
      <figcaption class="media-caption">{warn.alt_zh}</figcaption>
    </figure>
    <p class="muted" lang="ko">새우젓 빼주세요</p>
  </section>

  <section class="surface-warm">
    <h2 style="margin-top:0">豬肉湯飯候選清單</h2>
    <figure class="media-block">
      <img src={mediaPublicUrl(base, porkCard)} alt={porkCard.alt_zh} loading="lazy" />
      <figcaption class="media-caption">{porkCard.alt_zh}</figcaption>
    </figure>
    <ul class="list">
      <li>合天／Anmok／Namakzip：可吃候選，不是低體力日的強迫任務</li>
      <li>常見配料含蝦醬；官方旅遊說明也把蝦醬當調味選項</li>
    </ul>
  </section>

  <section class="surface">
    <h2 style="margin-top:0">烤肉部位比較</h2>
    <figure class="media-block">
      <img src={mediaPublicUrl(base, bbq)} alt={bbq.alt_zh} loading="lazy" />
      <figcaption class="media-caption">{bbq.alt_zh}</figcaption>
    </figure>
    <p class="muted">選簡單好烤部位；不為名店硬排。不喝酒，餐點以肉／蔬菜為主。</p>
  </section>

  <section class="surface">
    <h2 style="margin-top:0">市場小吃辨識</h2>
    <figure class="media-block">
      <img src={mediaPublicUrl(base, market)} alt={market.alt_zh} loading="lazy" />
      <figcaption class="media-caption">{market.alt_zh}</figcaption>
    </figure>
  </section>

  <section class="surface-warm">
    <h2 style="margin-top:0">排隊還是改備案</h2>
    <figure class="media-block">
      <img src={mediaPublicUrl(base, queue)} alt={queue.alt_zh} loading="lazy" />
      <figcaption class="media-caption">{queue.alt_zh}</figcaption>
    </figure>
  </section>

  <section class="surface-quiet">
    <h2 style="margin-top:0">候選店清單</h2>
    <p class="muted">以下為教材候選清單／占位，不是已訂位清單。</p>
  </section>

  {
    restaurants.map((r) => (
      <section class="surface">
        <h2 style="margin-top:0">{r.name_zh}</h2>
        <p>
          <span lang="ko">{r.name_ko}</span>
        </p>
        <p class="muted">
          {cityZh(r.city)}／{areaZh(r.area)} · {statusZh(r.status)}
        </p>
        <p>
          甲殼類風險：{riskZh(r.crustacean_risk)} · 排隊：{riskZh(r.queue_risk)}
        </p>
        <p>{sanitizeReaderText(r.recommend_reason)}</p>
        <p class="muted">風險：{sanitizeReaderText(r.risks)}</p>
        {r.menu_order_ko && <p>點餐：{sanitizeReaderText(r.menu_order_ko)}</p>}
        {r.naver_map_url && (
          <a class="btn primary" href={r.naver_map_url} target="_blank" rel="noreferrer">
            開啟 Naver Map
          </a>
        )}
      </section>
    ))
  }

  <section class="surface-quiet" aria-label="相關行程日">
    <h2 style="margin-top:0">相關行程日</h2>
    <div class="btn-row">
      {relatedDays.map((d) => (
        <a class="btn" href={`${base}${d.href}`}>{d.label}</a>
      ))}
      <a class="btn" href={`${base}guides/`}>教材目錄</a>
    </div>
  </section>
</Handbook>
