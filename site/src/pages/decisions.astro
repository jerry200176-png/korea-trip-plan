---
import Handbook from "../layouts/Handbook.astro";
import { loadFounderDecisions } from "../lib/data";

const decisions = loadFounderDecisions();
const base = import.meta.env.BASE_URL;
---
<Handbook title="Founder Decisions" current="more">
  <h1>Founder Decisions</h1>
  <p class="muted">Source: data/founder-decisions.yaml · 僅 D1–D3</p>
  {
    decisions.map((d) => (
      <section class="panel">
        <h2>
          {d.id} · {d.title_zh}
        </h2>
        <span class="badge decision">{d.status}</span>
        <p><strong>為何現在要決定：</strong>{d.why_now}</p>
        <p><strong>已確認：</strong></p>
        <ul>
          {d.confirmed_facts.map((f: string) => (
            <li>{f}</li>
          ))}
        </ul>
        <p><strong>Assumptions：</strong></p>
        <ul>
          {d.assumptions.map((f: string) => (
            <li>{f}</li>
          ))}
        </ul>
        {d.recommendation && (
          <p>
            <strong>建議（仍 DecisionRequired）：</strong>
            {d.recommendation}
          </p>
        )}
        <p><strong>選項（最多三個）：</strong></p>
        {d.options.map((o: any) => (
          <div class="block">
            <strong>{o.id}</strong> · {o.label}
            <p class="muted">{o.summary}</p>
            <p class="muted">
              影響 — 品質:{o.impacts.quality} · 體力:{o.impacts.energy} · 交通損耗:
              {o.impacts.transit_loss} · 飲食:{o.impacts.food} · 海灘:{o.impacts.beach_scenery} ·
              購物:{o.impacts.shopping} · 成本:{o.impacts.cost} · 研究重工:
              {o.impacts.research_effort}
            </p>
          </div>
        ))}
        <p><strong>最晚決策：</strong>{d.decide_by}</p>
        <p>
          <strong>回覆格式：</strong>
          <code>{d.reply_one_line}</code>
        </p>
      </section>
    ))
  }
</Handbook>
