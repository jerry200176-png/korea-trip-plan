---
import { siteBase } from "../lib/base";
import Handbook from "../layouts/Handbook.astro";
import { loadFounderDecisions } from "../lib/data";
import { sanitizeReaderText, statusClass, statusZh } from "../lib/presentation";

const decisions = loadFounderDecisions();
const base = siteBase();

function decisionTone(status: string) {
  if (status === "Confirmed") return "is-confirmed";
  if (status === "DecisionRequired") return "is-decision";
  return "is-provisional";
}
---
<Handbook title="一起決定" current="">
  <header class="page-intro">
    <p class="eyebrow">出發前</p>
    <h1 class="page-title">一起決定</h1>
    <p class="hero-lede">已決定與仍暫定的項目分開標示 — 方便兩人討論。</p>
  </header>

  {
    decisions.map((d) => (
      <section class={`surface decision-card ${decisionTone(d.status)} reveal`}>
        <div class="meta-row" style="margin-top:0">
          <span class={`status ${statusClass(d.status)}`}>{statusZh(d.status)}</span>
        </div>
        <h2 style="margin-top:var(--space-3)">
          {d.title_zh}
        </h2>
        <p>
          <strong>為什麼現在要談：</strong>
          {sanitizeReaderText(d.why_now)}
        </p>
        <p>
          <strong>已決定的事實：</strong>
        </p>
        <ul>
          {d.confirmed_facts.map((f: string) => (
            <li>{sanitizeReaderText(f)}</li>
          ))}
        </ul>
        {d.recommendation && (
          <p>
            <strong>建議：</strong>
            {sanitizeReaderText(d.recommendation)}
          </p>
        )}
        <p>
          <strong>選項：</strong>
        </p>
        {d.options.map((o: any) => (
          <div class="decision-option">
            <strong>{sanitizeReaderText(o.label)}</strong>
            <p class="muted">{sanitizeReaderText(o.summary)}</p>
          </div>
        ))}
        <p class="muted">
          <strong>最晚：</strong>
          {sanitizeReaderText(d.decide_by)}
        </p>
      </section>
    ))
  }
  <a class="back-link" href={`${base}`}>← 首頁</a>
</Handbook>
