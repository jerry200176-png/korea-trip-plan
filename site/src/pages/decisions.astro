---
import { siteBase } from "../lib/base";
import Handbook from "../layouts/Handbook.astro";
import { loadFounderDecisions } from "../lib/data";

const decisions = loadFounderDecisions();
const base = siteBase();

function statusClass(s: string) {
  if (s === "Confirmed") return "status-confirmed";
  if (s === "DecisionRequired") return "status-decision";
  if (s === "Assumption") return "status-assumption";
  return "status-provisional";
}

function statusZh(s: string) {
  const map: Record<string, string> = {
    Confirmed: "已確認",
    Provisional: "暫定",
    Assumption: "假設",
    DecisionRequired: "待決策",
  };
  return map[s] ?? s;
}
---
<Handbook title="一起決定" current="decisions">
  <p class="eyebrow">出發前</p>
  <h1 class="page-title">一起決定</h1>
  <p class="hero-lede">已確認與仍暫定的項目分開標示 — 方便兩人討論。</p>
  {
    decisions.map((d) => (
      <section class="surface decision-card">
        <h2 style="margin-top:0">
          {d.title_zh}
        </h2>
        <span class={`status ${statusClass(d.status)}`}>{statusZh(d.status)}</span>
        <p style="margin-top:var(--space-3)">
          <strong>為什麼現在要談：</strong>
          {d.why_now}
        </p>
        <p>
          <strong>已確認：</strong>
        </p>
        <ul>
          {d.confirmed_facts.map((f: string) => (
            <li>{f}</li>
          ))}
        </ul>
        {d.recommendation && (
          <p>
            <strong>建議：</strong>
            {d.recommendation}
          </p>
        )}
        <p>
          <strong>選項：</strong>
        </p>
        {d.options.map((o: any) => (
          <div class="decision-option">
            <strong>{o.label}</strong>
            <p class="muted">{o.summary}</p>
          </div>
        ))}
        <p class="muted">
          <strong>最晚：</strong>
          {d.decide_by}
        </p>
      </section>
    ))
  }
  <a class="btn" href={`${base}`}>← 首頁</a>
</Handbook>
