---
import { siteBase } from "../../lib/base";
import Handbook from "../../layouts/Handbook.astro";
import { GUIDES_HUB } from "../../lib/guide-links";

const base = siteBase();
---
<Handbook title="教材" current="guides">
  <p class="eyebrow">教材入口</p>
  <h1 class="page-title">旅行教材</h1>
  <span class="status status-provisional">目前暫定</span>
  <p class="muted">給 Jerry 與 Nikita 的高價值教材。交通、食物、出發前不再藏在「更多」。</p>

  <nav class="guides-hub" aria-label="教材目錄">
    <ul class="guides-hub-list">
      {
        GUIDES_HUB.map((g) => (
          <li>
            <a class="guides-hub-link" href={`${base}${g.href}`}>
              <span class="guides-hub-label">{g.label}</span>
              <span class="guides-hub-blurb muted">{g.blurb}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <p class="muted" style="margin-top:var(--space-4)">
    也需要：
    <a href={`${base}packing/`}>行李清單</a>
    ·
    <a href={`${base}decisions/`}>一起決定</a>
    ·
    <a href={`${base}days/`}>七天旅程</a>
  </p>
</Handbook>
