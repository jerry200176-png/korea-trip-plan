---
import { siteBase } from "../../lib/base";
import Handbook from "../../layouts/Handbook.astro";
import { relatedGuidesForDay } from "../../lib/guide-links";
import { loadItinerary, loadPhotoMemory, loadPlaces, loadRestaurants, loadTrip, mediaById, mediaPublicUrl } from "../../lib/data";
import {
  areaZh,
  cityZh,
  formatClock,
  kindZh,
  placeTypeZh,
  readerRefLabel,
  reservationLabel,
  sanitizeReaderText,
  statusZh,
  transitModeZh,
  tripDayLabel,
  walkingZh,
} from "../../lib/presentation";

export function getStaticPaths() {
  const days = loadItinerary().days;
  return days.map((d) => ({ params: { day: `day-${d.day_index}` } }));
}

const dayParam = Astro.params.day!;
const dayIndex = Number(dayParam.replace("day-", ""));
const day = loadItinerary().days.find((d) => d.day_index === dayIndex)!;
const trip = loadTrip();
const dayCal = tripDayLabel(trip.start_date, dayIndex);
const places = Object.fromEntries(loadPlaces().map((p) => [p.id, p]));
const restaurants = Object.fromEntries(loadRestaurants().map((r) => [r.id, r]));
const base = siteBase();
const nextDay = dayIndex < 7 ? dayIndex + 1 : null;

const cityClass =
  day.city === "Seoul" ? "seoul" : day.city === "Busan" || day.primary_areas?.some((a: string) => a.includes("Busan")) ? "busan" : "";

const dayMediaId =
  dayIndex === 1
    ? "incheon-arrival-flow"
    : dayIndex === 2
      ? "day2-hanbok-compare"
      : dayIndex === 3
        ? "day3-myeongdong-route"
        : dayIndex === 4
          ? "day4-feasibility-diagram"
          : dayIndex === 5
            ? "seoul-busan-ktx-journey"
            : dayIndex === 6
              ? "day6-core-low-energy"
              : dayIndex === 7
                ? "busan-station-to-hotel"
                : null;
const dayMedia = dayMediaId ? mediaById(dayMediaId) : null;
const dayVisualClass = dayMedia?.type === "map" ? "day-visual day-visual-diagram" : "day-visual";

const expectLine =
  dayIndex === 1
    ? "入境安頓＋交通卡；不追景點"
    : dayIndex === 2
      ? "韓服與宮殿合照"
      : dayIndex === 3
        ? "明洞單區：化妝品＋退稅＋衣服，不跨區硬塞"
        : dayIndex === 6
          ? "海岸線兩人照"
          : dayIndex === 4
            ? "江南輕量日：休息與購物補齊；算命僅在預約確認後"
            : dayIndex === 5
              ? "KTX 移動安頓；票未買前只跟流程"
              : dayIndex === 7
                ? "依航班緩衝前往機場；可刪購物"
                : day.one_priority;

const relatedGuides = relatedGuidesForDay(dayIndex);
const photoPlan = (loadPhotoMemory().daily_plans ?? []).find((p: { day: number }) => p.day === dayIndex);
---
<Handbook title={`第 ${day.day_index} 天`} current="days">
  <p class="muted"><a href={`${base}days/`}>← 全部行程</a></p>
  <p class="eyebrow">Day {day.day_index}{dayCal ? ` · ${dayCal}` : ""} · {cityZh(day.city)}</p>
  <h1 class="page-title">{sanitizeReaderText(day.theme)}</h1>
  <span class="status status-provisional">{statusZh(day.status)}</span>

  {
    dayMedia && (
      <figure class={dayVisualClass}>
        <img src={mediaPublicUrl(base, dayMedia)} alt={dayMedia.alt_zh} loading="lazy" />
        <figcaption class="media-caption">{dayMedia.alt_zh}</figcaption>
      </figure>
    )
  }
  {
    dayIndex === 1 && (
      <figure class="day-visual day-visual-diagram">
        <img src={mediaPublicUrl(base, mediaById("arex-vs-airport-bus")!)} alt={mediaById("arex-vs-airport-bus")!.alt_zh} loading="lazy" />
        <figcaption class="media-caption">{mediaById("arex-vs-airport-bus")!.alt_zh}</figcaption>
      </figure>
    )
  }
  {
    dayIndex === 1 && (
      <figure class="day-visual day-visual-diagram">
        <img src={mediaPublicUrl(base, mediaById("transport-card-payment-guide")!)} alt={mediaById("transport-card-payment-guide")!.alt_zh} loading="lazy" />
        <figcaption class="media-caption">{mediaById("transport-card-payment-guide")!.alt_zh}</figcaption>
      </figure>
    )
  }
  {
    dayIndex === 2 && (
      <figure class="day-visual day-visual-diagram">
        <img src={mediaPublicUrl(base, mediaById("day2-palace-areas")!)} alt={mediaById("day2-palace-areas")!.alt_zh} loading="lazy" />
        <figcaption class="media-caption">{mediaById("day2-palace-areas")!.alt_zh}</figcaption>
      </figure>
    )
  }
  {
    dayIndex === 2 && (
      <figure class="day-visual day-visual-diagram">
        <img src={mediaPublicUrl(base, mediaById("day2-low-energy")!)} alt={mediaById("day2-low-energy")!.alt_zh} loading="lazy" />
        <figcaption class="media-caption">{mediaById("day2-low-energy")!.alt_zh}</figcaption>
      </figure>
    )
  }
  {
    dayIndex === 5 && (
      <figure class="day-visual day-visual-diagram">
        <img src={mediaPublicUrl(base, mediaById("busan-station-to-hotel")!)} alt={mediaById("busan-station-to-hotel")!.alt_zh} loading="lazy" />
        <figcaption class="media-caption">{mediaById("busan-station-to-hotel")!.alt_zh}</figcaption>
      </figure>
    )
  }
  {
    dayIndex === 5 && (
      <figure class="day-visual day-visual-diagram">
        <img src={mediaPublicUrl(base, mediaById("lost-wrong-train-recovery")!)} alt={mediaById("lost-wrong-train-recovery")!.alt_zh} loading="lazy" />
        <figcaption class="media-caption">{mediaById("lost-wrong-train-recovery")!.alt_zh}</figcaption>
      </figure>
    )
  }
  {
    dayIndex === 6 && (
      <figure class="day-visual day-visual-diagram">
        <img src={mediaPublicUrl(base, mediaById("gwangalli-optional")!)} alt={mediaById("gwangalli-optional")!.alt_zh} loading="lazy" />
        <figcaption class="media-caption">{mediaById("gwangalli-optional")!.alt_zh}</figcaption>
      </figure>
    )
  }
  {
    dayIndex === 7 && (
      <figure class="day-visual day-visual-diagram">
        <img src={mediaPublicUrl(base, mediaById("offline-emergency-transport-card")!)} alt={mediaById("offline-emergency-transport-card")!.alt_zh} loading="lazy" />
        <figcaption class="media-caption">{mediaById("offline-emergency-transport-card")!.alt_zh}</figcaption>
      </figure>
    )
  }

  <section class={`surface city-ribbon ${cityClass}`}>
    <h2 style="margin-top:0">今天最重要</h2>
    <p style="font-size:1.1rem">{sanitizeReaderText(day.one_priority)}</p>
    <p class="muted">
      出門 {day.out_time} · 最晚回住宿 {day.return_by} · 步行強度 {walkingZh(day.walking_level)}
    </p>
    <p class="muted">區域：{(day.primary_areas || []).map(areaZh).join("／")}</p>
  </section>

  <section class="surface-warm">
    <h2 style="margin-top:0">這一天最期待</h2>
    <p style="margin:0">{sanitizeReaderText(expectLine)}</p>
  </section>

  <section class="surface-quiet">
    <h2 style="margin-top:0">時間軸</h2>
    <div class="route-line">
    {
      day.blocks.map((b: any) => {
        const place = b.place_id ? places[b.place_id] : null;
        const rest = b.restaurant_id ? restaurants[b.restaurant_id] : null;
        const isTransit = b.kind === "transit";
        const typeLabel = place ? placeTypeZh(place.type) : null;
        const transit = transitModeZh(b.transit_mode);
        return (
          <article class={`route-node ${isTransit ? "transit" : ""}`}>
              <div class="time">
                {formatClock(b.start)} – {formatClock(b.end)}
              </div>
              <h3 style="margin:0.2rem 0">{sanitizeReaderText(b.title)}</h3>
              <p class="muted">
                {kindZh(b.kind)}
                {b.droppable ? " · 體力不足可刪" : ""}
              </p>
              {place && (
                <>
                  <p>
                    <strong>{place.name_zh}</strong> · <span lang="ko">{place.name_ko}</span>
                    {typeLabel ? ` · ${typeLabel}` : ""}
                  </p>
                  <p class="muted">
                    {place.area ? `${areaZh(place.area)}` : "區域出發前確認"}
                    {place.address ? ` · 地址出發前再確認` : ""}
                  </p>
                  <p class="muted">
                    {reservationLabel(b.reservation_deadline, place.reservation_required)}
                  </p>
                  <div class="btn-row">
                    {place.naver_map_url && (
                      <a class="btn primary" href={place.naver_map_url} target="_blank" rel="noreferrer">
                        開啟 Naver Map
                      </a>
                    )}
                  </div>
                </>
              )}
              {!place && b.reservation_deadline && (
                <p class="muted">{reservationLabel(b.reservation_deadline, null)}</p>
              )}
              {rest && (
                <p>
                  餐飲：{rest.name_zh} / <span lang="ko">{rest.name_ko}</span>（{statusZh(rest.status)}）
                </p>
              )}
              {b.kind === "meal" && !rest && (
                <p class="muted">餐廳：店家鎖定後補上</p>
              )}
              {transit && (
                <p class="muted">
                  {transit}
                  {b.transit_minutes != null ? ` · 約 ${b.transit_minutes} 分` : " · 移動時間出發前確認"}
                </p>
              )}
              {b.plan_b && (
                <p>
                  <strong>備案：</strong>
                  {sanitizeReaderText(b.plan_b)}
                </p>
              )}
            </article>
        );
      })
    }
    </div>
  </section>

  <section class="surface">
    <h2 style="margin-top:0">備案</h2>
    <p>
      <strong>雨備：</strong>
      {sanitizeReaderText(day.rain_plan)}
    </p>
    <p>
      <strong>低體力優先刪除：</strong>
      {(day.droppable_items || []).map((x: string) => readerRefLabel(String(x), places)).join("、") || sanitizeReaderText(day.low_energy_plan)}
    </p>
    <p>
      <strong>低體力方案：</strong>
      {sanitizeReaderText(day.low_energy_plan)}
    </p>
    <p>
      <strong>回住宿方向：</strong>
      {sanitizeReaderText(day.emergency_return)}
    </p>
  </section>

  {
    photoPlan && (
      <section class="surface-warm" aria-label="今日拍照與回憶">
        <h2 style="margin-top:0">今日拍照與回憶</h2>
        <p>
          <strong>主時刻：</strong>
          {photoPlan.primary_moment}
        </p>
        <p class="muted">
          備案：{photoPlan.backup_or_rain} · {photoPlan.ask_stranger ? "可請路人" : "通常自助／倒數"}
        </p>
        <p>
          <strong>回憶提示：</strong>
          {(photoPlan.memory_prompts || []).join("／")}
        </p>
        <a class="btn" href={`${base}photo/`}>
          打開拍照教材
        </a>
      </section>
    )
  }

  <section class="surface-quiet related-guides" aria-label="相關教材">
    <h2 style="margin-top:0">這天相關教材</h2>
    <div class="btn-row">
      {
        relatedGuides.map((g) => (
          <a class="btn" href={`${base}${g.href}`}>
            {g.label}
          </a>
        ))
      }
      <a class="btn" href={`${base}guides/`}>全部教材</a>
    </div>
  </section>

  <div class="btn-row">
    <a class="btn primary" href={`${base}today/${dayParam}/`}>今日模式</a>
    {nextDay && <a class="btn" href={`${base}days/day-${nextDay}/`}>Day {nextDay}</a>}
    <a class="btn" href={`${base}emergency/`}>緊急</a>
  </div>
</Handbook>
