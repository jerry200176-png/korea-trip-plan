---
import { siteBase } from "../../lib/base";
import Handbook from "../../layouts/Handbook.astro";
import { loadItinerary, mediaById, mediaPublicUrl } from "../../lib/data";

const days = loadItinerary().days.slice().sort((a, b) => a.day_index - b.day_index);
const base = siteBase();
const seoul = mediaById("seoul-chapter")!;
const busan = mediaById("busan-chapter")!;
const ktx = mediaById("ktx-transition")!;
---
<Handbook title="行程" current="days">
  <p class="eyebrow">7 days</p>
  <h1 class="page-title">每日行程</h1>
  <p class="muted">首爾四晚 · KTX · 釜山兩晚。狀態皆為目前暫定。</p>

  <section class="chapter-visual">
    <img src={mediaPublicUrl(base, seoul)} alt={seoul.alt_zh} loading="lazy" />
    <p class="media-caption">首爾章節</p>
  </section>
  <ul class="list">
    {
      days
        .filter((d) => d.city === "Seoul")
        .map((d) => (
          <li>
            <a href={`${base}days/day-${d.day_index}/`}>
              <strong>Day {d.day_index}</strong> · {d.theme}
            </a>
            <div class="muted">{d.one_priority}</div>
          </li>
        ))
    }
  </ul>

  <section class="chapter-visual">
    <img src={mediaPublicUrl(base, ktx)} alt={ktx.alt_zh} loading="lazy" />
    <p class="media-caption">KTX 移動</p>
  </section>
  <ul class="list">
    {
      days
        .filter((d) => d.city === "Transit")
        .map((d) => (
          <li>
            <a href={`${base}days/day-${d.day_index}/`}>
              <strong>Day {d.day_index}</strong> · {d.theme}
            </a>
            <div class="muted">{d.one_priority}</div>
          </li>
        ))
    }
  </ul>

  <section class="chapter-visual">
    <img src={mediaPublicUrl(base, busan)} alt={busan.alt_zh} loading="lazy" />
    <p class="media-caption">釜山章節</p>
  </section>
  <ul class="list">
    {
      days
        .filter((d) => d.city === "Busan")
        .map((d) => (
          <li>
            <a href={`${base}days/day-${d.day_index}/`}>
              <strong>Day {d.day_index}</strong> · {d.theme}
            </a>
            <div class="muted">{d.one_priority}</div>
          </li>
        ))
    }
  </ul>
</Handbook>
