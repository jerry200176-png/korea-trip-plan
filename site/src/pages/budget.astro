---
import Handbook from "../layouts/Handbook.astro";
import { loadBudget, budgetProgress } from "../lib/data";
import { statusZh } from "../lib/presentation";
const budget = loadBudget();
const prog = budgetProgress(budget);
---
<Handbook title="預算" current="more">
  <h1>預算</h1>
  <section class="panel">
    <p>已花 {prog.spent} / 規劃 {prog.planned} {budget.currency}（{prog.pct}%）</p>
    <span class="status status-provisional">{statusZh(budget.status)}</span>
    <p class="muted">{budget.notes}</p>
  </section>
  <ul class="list">
    {budget.categories.map((c: any) => (
      <li>
        <strong>{c.name}</strong>
        <div>{c.spent_twd} / {c.planned_twd} TWD · {statusZh(c.status)}</div>
        {c.notes && <div class="muted">{c.notes}</div>}
      </li>
    ))}
  </ul>
</Handbook>
