---
import Handbook from "../layouts/Handbook.astro";
import { loadTimeline } from "../lib/data";
const timeline = loadTimeline();
const base = import.meta.env.BASE_URL;
---
<Handbook title="Before You Go" current="more">
  <h1>Before You Go</h1>
  <p class="muted">對應 data/timeline.yaml 與 checklists/</p>
  {timeline.milestones.map((m) => (
    <section class="panel">
      <h2>{m.label}</h2>
      <ul class="list">
        {m.tasks.map((t: any) => (
          <li>
            <label style="display:flex;gap:0.6rem;align-items:flex-start">
              <input type="checkbox" disabled checked={t.done} />
              <span>{t.title}</span>
            </label>
          </li>
        ))}
      </ul>
    </section>
  ))}
  <div class="btn-row">
    <a class="btn" href={`${base}packing/`}>行李</a>
    <a class="btn" href={`${base}bookings/`}>預訂占位</a>
  </div>
  <section class="panel">
    <h2>研究章節（handbook/）</h2>
    <p class="muted">有來源、可查核日；出發前請重讀標記 Stale 的段落。</p>
    <ul class="list">
      <li>入境與規定 — <code>handbook/entry-and-rules.md</code></li>
      <li>交通 — <code>handbook/city-transport.md</code> · <a href={`${base}transport/`}>網站摘要</a></li>
      <li>網路與支付 — <code>handbook/connectivity-and-payments.md</code></li>
      <li>天氣 — <code>handbook/weather.md</code></li>
      <li>航班與機場 — <code>handbook/flights-and-airports.md</code></li>
    </ul>
    <p class="muted">對應 <code>checklists/pre-departure.md</code></p>
  </section>
</Handbook>
