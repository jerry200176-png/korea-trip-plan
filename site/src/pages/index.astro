---
import Handbook from "../layouts/Handbook.astro";
const base = import.meta.env.BASE_URL;
---
<Handbook title="我們的韓國旅行" current="home">
  <section class="panel">
    <h1 style="margin-top:0">我們的第一次韓國旅行</h1>
    <p style="margin:0.4rem 0 0.8rem">目前方案：<strong>Seoul 4N + Busan 2N</strong></p>
    <p class="muted" style="margin-top:0">旅行月份：2027 年 3 月（日期待確認）</p>
    <div class="btn-row">
      <a class="btn primary" href={`${base}days/`}>查看 7 天行程</a>
      <a class="btn primary" href={`${base}today/`}>今天模式</a>
      <a class="btn" href={`${base}decisions/`}>我們需要一起決定的事情</a>
    </div>
  </section>

  <section class="panel">
    <h2>目前狀態</h2>
    <ul class="list">
      <li><strong>已決定：</strong>D2 城市晚數 = Seoul 4N + Busan 2N</li>
      <li><strong>暫定：</strong>D3 目標航線 = TPE → ICN，PUS → TPE（直飛優先）</li>
      <li><strong>還要一起決定：</strong>D1 確切日期（目前只先用 2027 年 3 月）</li>
      <li><strong>出發前要再確認：</strong>實際航班、KTX、住宿供應、入境規則最新公告</li>
    </ul>
  </section>

  <section class="panel">
    <h2>你們在意的重點</h2>
    <p class="muted">GOT7、購物、韓服、海景、豬肉湯飯、09:00–21:00 行程節奏</p>
    <div class="btn-row">
      <a class="btn" href={`${base}days/day-2/`}>韓服/宮殿（首爾）</a>
      <a class="btn" href={`${base}days/day-3/`}>購物（首爾）</a>
      <a class="btn" href={`${base}days/day-6/`}>海景（釜山）</a>
    </div>
  </section>

  <section class="panel">
    <h2>手機離線備用</h2>
    <p class="muted">可以直接下載 PDF 放手機，沒網路也能看。</p>
    <div class="btn-row">
      <a class="btn primary" href={`${base}downloads/korea-trip-handbook.pdf`}>Handbook PDF</a>
      <a class="btn" href={`${base}downloads/emergency-pack.pdf`}>Emergency PDF</a>
    </div>
  </section>
</Handbook>
