---
import Handbook from "../layouts/Handbook.astro";
---
<Handbook title="交通" current="more">
  <p class="eyebrow">交通</p>
  <h1 class="page-title">地圖與交通</h1>

  <section class="surface">
    <h2 style="margin-top:0">必裝 App</h2>
    <ul class="list">
      <li>
        <a href="https://map.naver.com" target="_blank" rel="noreferrer">Naver Map</a> — 路線與出口
      </li>
      <li>
        <a href="https://map.kakao.com" target="_blank" rel="noreferrer">Kakao Map</a> — 備援導航
      </li>
      <li>
        <a href="https://www.t-money.co.kr" target="_blank" rel="noreferrer">T-money</a> — 交通卡資訊
      </li>
      <li>
        <a href="https://www.letskorail.com" target="_blank" rel="noreferrer">Korail</a> — KTX
      </li>
    </ul>
  </section>

  <section class="surface">
    <h2 style="margin-top:0">本趟原則</h2>
    <p>不租車 · 每天最多 1–2 個相鄰區域 · 腳痠就改計程車 · 移動日不塞景點</p>
    <p class="muted">Jerry 與 Nikita 以大眾運輸為主，轉乘越少越好。</p>
  </section>
</Handbook>
