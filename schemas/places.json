{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://korea-trip.local/schemas/place.json",
  "type": "object",
  "required": ["places"],
  "properties": {
    "places": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id", "name_zh", "name_ko", "name_en", "type", "city", "area",
          "address", "recommend_reason", "risks", "source_ids", "checked_at", "status"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^plc-" },
          "name_zh": { "type": "string" },
          "name_ko": { "type": "string" },
          "name_en": { "type": "string" },
          "type": { "type": "string" },
          "city": { "type": "string" },
          "area": { "type": "string" },
          "address": { "type": "string" },
          "naver_map_url": { "type": ["string", "null"] },
          "google_maps_url": { "type": ["string", "null"] },
          "official_url": { "type": ["string", "null"] },
          "opening_hours": { "type": ["string", "null"] },
          "closed_days": { "type": ["string", "null"] },
          "estimated_dwell_minutes": { "type": ["integer", "null"] },
          "estimated_cost_krw": { "type": ["integer", "null"] },
          "reservation_required": { "type": ["boolean", "null"] },
          "queue_risk": { "type": "string", "enum": ["low", "medium", "high", "unknown"] },
          "indoor_outdoor": { "type": "string", "enum": ["indoor", "outdoor", "mixed", "unknown"] },
          "rain_ok": { "type": ["boolean", "null"] },
          "best_time_of_day": { "type": ["string", "null"] },
          "nearby_place_ids": { "type": "array", "items": { "type": "string" } },
          "recommend_reason": { "type": "string" },
          "risks": { "type": "string" },
          "source_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "checked_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "status": { "type": "string", "enum": ["Confirmed", "Provisional", "Assumption", "DecisionRequired", "Stale"] }
        }
      }
    }
  }
}
