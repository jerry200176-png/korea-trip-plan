{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://korea-trip.local/schemas/destinations.json",
  "type": "object",
  "required": ["destinations"],
  "properties": {
    "destinations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name_zh", "name_ko", "name_en", "role", "status"],
        "properties": {
          "id": { "type": "string" },
          "name_zh": { "type": "string" },
          "name_ko": { "type": "string" },
          "name_en": { "type": "string" },
          "role": { "type": "string" },
          "provisional_nights": { "type": ["integer", "null"] },
          "airports": { "type": "array", "items": { "type": "string" } },
          "why": { "type": "string" },
          "status": { "type": "string", "enum": ["Confirmed", "Provisional", "Assumption", "DecisionRequired", "Stale"] }
        }
      }
    }
  }
}
