{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://korea-trip.local/schemas/lodging-area-scores.json",
  "type": "object",
  "required": ["id", "status", "updated", "depends_on", "dimensions", "seoul", "busan"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "status": { "type": "string", "enum": ["Confirmed", "Provisional", "Assumption", "DecisionRequired", "Stale"] },
    "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "depends_on": {
      "type": "object",
      "required": ["route", "flight_plan"],
      "properties": {
        "route": { "type": "string" },
        "flight_plan": { "type": "string" }
      }
    },
    "dimensions": {
      "type": "array",
      "minItems": 14,
      "items": {
        "type": "object",
        "required": ["id", "label_zh"],
        "properties": {
          "id": { "type": "string" },
          "label_zh": { "type": "string" }
        }
      }
    },
    "seoul": { "$ref": "#/$defs/cityBlock" },
    "busan": { "$ref": "#/$defs/cityBlock" }
  },
  "$defs": {
    "scoreCell": {
      "type": "object",
      "required": ["score", "epistemic", "rationale", "source_ids"],
      "properties": {
        "score": { "type": ["integer", "null"], "minimum": 1, "maximum": 5 },
        "epistemic": { "type": "string", "enum": ["Fact", "Inference", "Assumption"] },
        "rationale": { "type": "string" },
        "source_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "area": {
      "type": "object",
      "required": ["id", "label", "scores"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "included_reason": { "type": "string" },
        "scores": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/scoreCell" }
        }
      }
    },
    "cityBlock": {
      "type": "object",
      "required": ["recommendation", "areas"],
      "properties": {
        "recommendation": {
          "type": "object",
          "required": ["primary", "backup", "status"],
          "properties": {
            "primary": { "type": "string" },
            "backup": { "type": "string" },
            "status": { "type": "string" },
            "summary_zh": { "type": "string" }
          }
        },
        "areas": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/area" }
        }
      }
    }
  }
}
