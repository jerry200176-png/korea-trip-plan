{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://korea-trip.local/schemas/travelers.json",
  "type": "object",
  "required": ["travelers"],
  "properties": {
    "travelers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "display_name", "role", "status"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "display_name": { "type": "string" },
          "role": { "type": "string" },
          "nationality_assumption": { "type": "string" },
          "interests": { "type": "array", "items": { "type": "string" } },
          "constraints": { "type": "array", "items": { "type": "string" } },
          "status": { "type": "string", "enum": ["Confirmed", "Provisional", "Assumption", "DecisionRequired", "Stale"] },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
